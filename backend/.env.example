PORT=8080
GOOGLE_DRIVE_FOLDER_ID=YOUR_FOLDER_ID

# ===== OAuth2 (recomendado para My Drive / cuenta personal) =====
GOOGLE_OAUTH_CLIENT_ID=YOUR_CLIENT_ID.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=YOUR_CLIENT_SECRET
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/google/callback
# Produccion en Vercel: usa almacenamiento persistente en Supabase para token OAuth
# GOOGLE_OAUTH_TOKEN_STORE=supabase
# GOOGLE_OAUTH_TOKEN_TABLE=oauth_tokens
# GOOGLE_OAUTH_TOKEN_KEY=google_drive_oauth
# Opcional: ruta del token OAuth guardado tras autorizar
# GOOGLE_OAUTH_TOKEN_PATH=/absolute/path/oauth-token.json

# ===== Supabase / PostgreSQL =====
# Puedes usar SUPABASE_URL directo o SUPABASE_PROJECT_ID para derivar URL.
SUPABASE_PROJECT_ID=your_project_id
SUPABASE_URL=
SUPABASE_SECRET_KEY=your_supabase_secret_key

# ===== Service Account (solo si usas Shared Drive real) =====
# GOOGLE_SERVICE_ACCOUNT_JSON_PATH=/absolute/path/to/service-account.json
# GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n"

# ===== Observabilidad e idempotencia =====
# TTL en ms para cache de idempotencia y cantidad maxima de eventos de auditoria en memoria
# IDEMPOTENCY_TTL_MS=600000
# MAX_AUDIT_EVENTS=500
